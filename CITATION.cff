    given-names: "Gabriel"

license: MIT

repository-code: "https://github.com/GabrielMoniz/hypergraph-functional-bounds"

keywords:
  - quantum information
  - hypergraph states
  - Bell inequalities
  - stabilizer formalism
  - Julia

